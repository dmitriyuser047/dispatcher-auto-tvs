{
  "name": "dispetcherizaciya-avto",
  "version": "2.0.17",
  "description": "Диспетчеризация авто группы компаний ООО Технрайз Велл Сервис",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tvs.dispetcherizaciya-avto",
    "productName": "Диспетчеризация авто ООО Технрайз Велл Сервис",
    "artifactName": "Dispatcher-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/node-unrar-js/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {},
  "dependencies": {
    "node-unrar-js": "^2.0.2"
  }
}
